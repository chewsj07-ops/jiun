{
  "entities": {
    "User": {
      "title": "User",
      "description": "用户众生相",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "joinDate": { "type": "string", "format": "date-time" },
        "karmaScore": { "type": "number" },
        "currentStreak": { "type": "number" }
      },
      "required": ["userId", "joinDate", "karmaScore", "currentStreak"]
    },
    "Vow": {
      "title": "Vow",
      "description": "愿力契约",
      "type": "object",
      "properties": {
        "vowId": { "type": "string" },
        "userId": { "type": "string" },
        "vowText": { "type": "string" },
        "target": { "type": "string", "enum": ["self", "family", "others"] },
        "status": { "type": "string", "enum": ["active", "completed", "broken"] }
      },
      "required": ["vowId", "userId", "vowText", "target", "status"]
    },
    "Session": {
      "title": "Session",
      "description": "实修记录",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "vowId": { "type": "string" },
        "duration": { "type": "number" },
        "actualDuration": { "type": "number" },
        "isCompleted": { "type": "boolean" },
        "reflection": { "type": "string" }
      },
      "required": ["sessionId", "vowId", "duration", "actualDuration", "isCompleted"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "用户数据"
    },
    "/vows/{vowId}": {
      "schema": "Vow",
      "description": "愿力契约"
    },
    "/sessions/{sessionId}": {
      "schema": "Session",
      "description": "实修记录"
    }
  }
}
